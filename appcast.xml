    <item>
      <title>0.2.1</title>
      <pubDate>Sat, 19 Jul 2026 08:20:00 +0900</pubDate>
      <sparkle:minimumSystemVersion>14.4</sparkle:minimumSystemVersion>
      <description><![CDATA[
        <h2>Groovyday 0.2.1</h2>
        <ul>
          <li>Full app menu now available from the window itself: hover the visualizer and open the mode switcher (Settings, Check for Updates, Quit), or right-click anywhere</li>
          <li>Fixes the app being unreachable when the menu bar icon is hidden (e.g. next to the MacBook notch)</li>
        </ul>
      ]]></description>
