    <item>
      <title>0.2.0</title>
      <pubDate>Sat, 19 Jul 2026 07:30:00 +0900</pubDate>
      <sparkle:minimumSystemVersion>14.4</sparkle:minimumSystemVersion>
      <description><![CDATA[
        <h2>Groovyday 0.2.0</h2>
        <ul>
          <li>First public build: five visualizers (Bars, Halo, Ambient, Particles, Skyline)</li>
          <li>Time-synced lyrics with per-mode toggles and timing control</li>
          <li>Four window modes with animated transitions, global hotkeys</li>
          <li>Music &amp; Spotify metadata, transport, and scrubbing</li>
        </ul>
      ]]></description>
